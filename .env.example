# ─── Recon.io Environment Variables ──────────────────────────────
# Copy file ini ke .env lalu sesuaikan.
# Semua variabel bersifat opsional — default sudah disediakan.

# Output directory
# RECON_OUTPUT_DIR=./results

# Timeout (detik) — global & per fase
# RECON_TIMEOUT=300
# RECON_TIMEOUT_SUBDOMAIN=300
# RECON_TIMEOUT_DNS=60
# RECON_TIMEOUT_PORTS=300
# RECON_TIMEOUT_FINGERPRINT=120
# RECON_TIMEOUT_URLS=180
# RECON_TIMEOUT_JS=300
# RECON_TIMEOUT_PARAMS=300
# RECON_TIMEOUT_SECURITY=360
# RECON_TIMEOUT_DIRBRUTE=600

# Batas jumlah file JS yang dianalisis (default: 50)
# RECON_JS_LIMIT=50

# User Agent
# RECON_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) ...

# Tool paths (kalau tidak di $PATH)
# RECON_TOOL_SUBFINDER=/usr/local/bin/subfinder
# RECON_TOOL_ALTERX=alterx
# RECON_TOOL_DNSX=dnsx
# RECON_TOOL_HTTPX=httpx
# RECON_TOOL_NMAP=/usr/bin/nmap
# RECON_TOOL_WAFW00F=wafw00f
# RECON_TOOL_KATANA=katana
# RECON_TOOL_NUCLEI=nuclei
# RECON_TOOL_FFUF=ffuf
# RECON_TOOL_NAABU=naabu

# Wordlist path
# RECON_WORDLIST=/usr/share/seclists/Discovery/Web-Content/common.txt

# ─── AI assistant (OPSIONAL) ─────────────────────────────────────
# Fitur AI (mode chat / saran serangan) butuh API key Google Gemini.
# recon TETAP jalan penuh tanpa ini — kosongkan saja kalau tidak dipakai.
#
# PENTING soal keamanan API key:
#   - Simpan HANYA di file .env ini. Jangan commit, jangan share, jangan paste ke chat/log.
#   - File .env sudah diabaikan git, jadi aman dari commit tak sengaja.
#   - Hanya kamu yang boleh tahu. Bisa di-revoke / rotate kapan saja di Google AI Studio.
# GEMINI_API_KEY=
# RECON_AI_MODEL=gemini-2.5-flash
# RECON_AI_TIMEOUT=120
# RECON_AI_MAX_TOKENS=4096
