# ╔══════════════════════════════════════════════════════════════════╗
# ║             recon.io — Konfigurasi Environment                  ║
# ║                                                                 ║
# ║  Cara pakai:                                                    ║
# ║    1. Copy file ini → .env       (cp .env.example .env)         ║
# ║    2. Isi value yang dibutuhkan                                 ║
# ║    3. Hapus '#' di depan baris yang ingin diaktifkan            ║
# ║                                                                 ║
# ║  Semua variabel OPSIONAL — default sudah disediakan.            ║
# ║  Baris tanpa '#' = AKTIF. Baris dengan '#' = NON-AKTIF.        ║
# ╚══════════════════════════════════════════════════════════════════╝


# ┌──────────────────────────────────────────────────────────────────┐
# │                     PENGATURAN UMUM                              │
# └──────────────────────────────────────────────────────────────────┘

# .env.example hapus menjadi .env agar script bisa membacanya
# Folder tempat hasil recon disimpan (default: ./results)
RECON_OUTPUT_DIR=./results

# User Agent yang digunakan untuk semua HTTP request
RECON_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Batas jumlah file JS yang dianalisis di fase js (default: 50)
RECON_JS_LIMIT=50


# ┌──────────────────────────────────────────────────────────────────┐
# │                    TIMEOUT (dalam detik)                         │
# │                                                                  │
# │  Atur timeout per fase. Naikkan jika target besar/lambat.        │
# │  Set RECON_TIMEOUT untuk override global semua fase sekaligus.   │
# └──────────────────────────────────────────────────────────────────┘

RECON_TIMEOUT=300

RECON_TIMEOUT_SUBDOMAIN=300
RECON_TIMEOUT_DNS=60
RECON_TIMEOUT_PORTS=300
RECON_TIMEOUT_FINGERPRINT=120
RECON_TIMEOUT_URLS=180
RECON_TIMEOUT_JS=300
RECON_TIMEOUT_PARAMS=300
RECON_TIMEOUT_SECURITY=360
RECON_TIMEOUT_DIRBRUTE=600


# ┌──────────────────────────────────────────────────────────────────┐
# │                    PATH KE TOOLS                                 │
# │                                                                  │
# │  Isi HANYA jika tool tidak ada di $PATH sistem.                  │
# │  Kalau sudah bisa dijalankan dari terminal, biarkan default.     │
# │  Cek: python recon.py --check                                   │
# └──────────────────────────────────────────────────────────────────┘

# -- ProjectDiscovery tools --
# RECON_TOOL_SUBFINDER=/usr/local/bin/subfinder
# RECON_TOOL_ALTERX=/usr/local/bin/alterx
# RECON_TOOL_DNSX=/usr/local/bin/dnsx
# RECON_TOOL_HTTPX=/usr/local/bin/httpx
# RECON_TOOL_KATANA=/usr/local/bin/katana
# RECON_TOOL_NUCLEI=/usr/local/bin/nuclei
# RECON_TOOL_NAABU=/usr/local/bin/naabu

# -- Fuzzer & scanner --
# RECON_TOOL_FFUF=/usr/local/bin/ffuf
# RECON_TOOL_NMAP=/usr/bin/nmap
# RECON_TOOL_WAFW00F=/usr/local/bin/wafw00f

# -- OSINT & enumeration --
# RECON_TOOL_AMASS=/usr/local/bin/amass
# RECON_TOOL_GAU=/usr/local/bin/gau
# RECON_TOOL_WAYBACKURLS=/usr/local/bin/waybackurls
# RECON_TOOL_ARJUN=/usr/local/bin/arjun
# RECON_TOOL_SUBZY=/usr/local/bin/subzy

# -- System tools --
# RECON_TOOL_CURL=/usr/bin/curl
# RECON_TOOL_DIG=/usr/bin/dig
# RECON_TOOL_WHOIS=/usr/bin/whois


# ┌──────────────────────────────────────────────────────────────────┐
# │                       WORDLIST                                   │
# │                                                                  │
# │  Path ke wordlist untuk directory brute-force (fase dirbrute).   │
# │  Kalau dikosongkan, akan otomatis cari di lokasi umum atau       │
# │  download fallback.                                              │
# └──────────────────────────────────────────────────────────────────┘

# RECON_WORDLIST=/usr/share/seclists/Discovery/Web-Content/common.txt


# ┌──────────────────────────────────────────────────────────────────┐
# │                   AI ASSISTANT (OPSIONAL)                        │
# │                                                                  │
# │  Fitur AI: mode chat, saran serangan, analisis report.           │
# │  Recon TETAP JALAN PENUH tanpa ini. Kosongkan jika tidak pakai.  │
# │                                                                  │
# │  ⚠  KEAMANAN API KEY:                                           │
# │     • Simpan HANYA di .env — jangan commit/share/paste ke log    │
# │     • File .env sudah di-ignore git                              │
# │     • Revoke/rotate kapan saja di dashboard provider             │
# └──────────────────────────────────────────────────────────────────┘

# Pilih SATU provider di bawah, uncomment bagian yang diinginkan.

# ─── Opsi 1: Google Gemini (DEFAULT, gratis di ai.google.dev) ─────
# GEMINI_API_KEY=PASTE_API_KEY_GEMINI_DISINI
# RECON_AI_MODEL=gemini-2.5-flash
# RECON_AI_TIMEOUT=120
# RECON_AI_MAX_TOKENS=4096

# ─── Opsi 2: Groq (gratis, cepat — console.groq.com) ────────────
# RECON_AI_PROVIDER=openai
# RECON_AI_BASE_URL=https://api.groq.com/openai/v1
# RECON_AI_MODEL=llama-3.3-70b-versatile
# GROQ_API_KEY=PASTE_API_KEY_GROQ_DISINI

# ─── Opsi 3: OpenRouter (openrouter.ai) ──────────────────────────
# RECON_AI_PROVIDER=openai
# RECON_AI_BASE_URL=https://openrouter.ai/api/v1
# RECON_AI_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_API_KEY=PASTE_API_KEY_OPENROUTER_DISINI

# ─── Opsi 4: Ollama (LOKAL — gratis, offline, tanpa key) ─────────
# RECON_AI_PROVIDER=openai
# RECON_AI_BASE_URL=http://localhost:11434/v1
# RECON_AI_MODEL=llama3.1
